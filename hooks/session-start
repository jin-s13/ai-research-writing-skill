#!/usr/bin/env bash
# SessionStart hook for AI Research Writing Skill.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${PLUGIN_ROOT}/SKILL.md"

if [ -f "$SKILL_FILE" ]; then
  skill_content="$(cat "$SKILL_FILE")"
else
  skill_content="AI Research Writing Skill is installed, but SKILL.md was not found."
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="<IMPORTANT>\nAI Research Writing Skill is available. For ML/AI/CV/NLP paper writing, revision, citation verification, figure planning, LaTeX drafting, reviewer checks, and submission packaging, follow the root SKILL.md. Load only the narrow references needed for the task.\n\nRoot SKILL.md:\n$(escape_for_json "$skill_content")\n</IMPORTANT>"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$context"
fi
